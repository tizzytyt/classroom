page {
  background: #f6f7fb;
  color: #111;
}

.card {
  margin: 24rpx;
  padding: 24rpx;
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 16rpx;
  background: #fff;
}

.btnPrimary {
  background: #007aff;
  color: #fff;
}

.btnDanger {
  background: #ff3b30;
  color: #fff;
}

.input {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.link {
  color: #007aff;
  font-size: 26rpx;
}

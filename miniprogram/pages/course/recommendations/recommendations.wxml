<view class="page">
  <view class="card">
    <view class="title">老师给你的推荐</view>
    <view class="sub">优先完成这些资源可提升学习效果</view>
  </view>

  <view class="card">
    <view wx:if="{{loading}}" class="tip">加载中...</view>
    <view wx:elif="{{!list.length}}" class="tip">暂无推荐资源</view>
    <block wx:else>
      <view wx:for="{{list}}" wx:key="pushId" class="item">
        <view class="name">{{item.title}}</view>
        <view class="meta">{{item.category}} · {{item.fileName}}</view>
        <view class="meta">推荐说明：{{item.reason || '无'}}</view>
        <view class="meta">状态：{{item.status === 1 ? '已读' : '未读'}}</view>
        <view class="ops">
          <button size="mini" class="miniBtn" data-item="{{item}}" bindtap="openRec">
            {{ isVideo(item.fileType, item.fileName) ? '观看视频' : '打开文件' }}
          </button>
        </view>
      </view>
    </block>
  </view>
</view>


.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tip {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

.rankItem {
  padding: 16rpx 0;
  border-top: 1px solid #f5f5f5;
}

.rankTop {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.rankNo {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #f0f5ff;
  color: #1677ff;
  font-size: 24rpx;
  flex-shrink: 0;
}

.rankStem {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}

.qItem {
  padding: 18rpx 0;
  border-top: 1px solid #f5f5f5;
}

.qStem {
  font-size: 26rpx;
  color: #333333;
}

.barTrack {
  height: 14rpx;
  border-radius: 999rpx;
  background: #f0f0f0;
  overflow: hidden;
  margin-top: 10rpx;
}

.barFill {
  height: 100%;
  border-radius: 999rpx;
  max-width: 100%;
}

.barScore {
  background: linear-gradient(90deg, #faad14 0%, #ffd666 100%);
}

.barCorrect {
  background: linear-gradient(90deg, #52c41a 0%, #73d13d 100%);
}


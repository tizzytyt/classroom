.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.meta {
  font-size: 26rpx;
  color: #666666;
  margin-top: 6rpx;
}

.qStem {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.qMeta {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.optLine {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #444444;
  margin-top: 10rpx;
  padding: 10rpx 8rpx;
  border-radius: 12rpx;
  background: #fafafa;
  border: 1px solid #f0f0f0;
}

.input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.saOps {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
}

.saList {
  margin-top: 10rpx;
}

.saItem {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #555555;
  padding: 8rpx 0;
}

.saName {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.saRemove {
  color: #ff4d4f;
  margin-left: 16rpx;
}

.btnRow {
  display: flex;
  gap: 16rpx;
}

.btnPrimary {
  flex: 1;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4b7cff 0%, #6fa4ff 100%);
  color: #ffffff;
  border: none;
}

.btnGhost {
  flex: 1;
  border-radius: 999rpx;
  background: #f5f5f5;
  color: #666666;
  border: none;
}

.tip {
  font-size: 24rpx;
  color: #888888;
  margin-top: 12rpx;
}


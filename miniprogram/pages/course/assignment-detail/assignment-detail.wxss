.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.titleRow {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  flex: 1;
}

.tagClosed {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #999999;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1px solid #d9d9d9;
  background: #fafafa;
}

.meta {
  font-size: 24rpx;
  color: #666666;
  margin-top: 4rpx;
}

.content {
  font-size: 26rpx;
  margin-top: 12rpx;
  color: #333333;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.hint {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.hint.warn {
  color: #d48806;
  font-weight: 500;
}

.btnSecondary {
  margin-bottom: 16rpx;
  border-radius: 999rpx;
  background: #f0f4ff;
  color: #4b7cff;
  border: 1px solid #d6e4ff;
  font-size: 28rpx;
}

.attachList {
  margin-bottom: 16rpx;
}

.attachRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1px solid #f0f0f0;
  font-size: 26rpx;
}

.attachName {
  flex: 1;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 16rpx;
}

.attachRemove {
  color: #ff4d4f;
  font-size: 26rpx;
}

.attachBlock {
  margin-top: 8rpx;
}

.attachLabel {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 6rpx;
}

.attachLink {
  font-size: 24rpx;
  color: #4b7cff;
  text-decoration: underline;
  margin-bottom: 4rpx;
  word-break: break-all;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.btn {
  border-radius: 999rpx;
}

.input {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.btnPrimary {
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4b7cff 0%, #6fa4ff 100%);
  color: #ffffff;
  border: none;
}

.btnGhost {
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #f5f6fb;
  color: #333333;
  border: none;
}

.studentSubmit {
  padding: 16rpx 0;
  border-top: 1px solid #f5f5f5;
}

.studentName {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.submitText {
  font-size: 26rpx;
  color: #333333;
  margin-top: 10rpx;
  white-space: pre-wrap;
}

.gradeBtnRow {
  margin-top: 10rpx;
}

.gradeBtn {
  border-radius: 999rpx;
}


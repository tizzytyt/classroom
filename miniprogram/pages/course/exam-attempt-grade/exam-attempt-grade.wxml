<view class="page">
  <view class="card" wx:if="{{detail}}">
    <view class="title">{{detail.paperTitle}}</view>
    <view class="meta">学生：{{detail.studentName}}</view>
    <view class="meta">提交时间：{{detail.submittedAt || '—'}}</view>
    <view class="meta">当前总分：{{detail.totalScore != null ? detail.totalScore : '—'}} · 客观题合计：{{detail.objectiveScore != null ? detail.objectiveScore : '—'}}</view>
  </view>

  <view class="card" wx:if="{{rows.length}}">
    <view class="sectionTitle">逐题得分</view>
    <view class="tip">得分不能超过该题满分；保存后自动重算总分与客观题合计。</view>
    <view wx:if="{{gradingDone}}" class="gradedTip">已批改</view>
    <block wx:for="{{rows}}" wx:key="questionId">
      <view class="qItem">
        <view class="qStem">{{index + 1}}. {{item.stem}}</view>
        <view class="qMeta">{{item.typeLabel}} · 满分 {{item.fullScore != null ? item.fullScore : '—'}} · 标准答案 {{item.correctAnswer || '—'}}</view>
        <view class="meta" style="margin-top:8rpx">学生作答</view>
        <view class="answerBox">{{item.studentAnswer || '（未作答）'}}</view>
        <view class="rowScore">
          <text class="scoreLabel">{{item.gradable ? '本题得分（教师批改）' : '本题得分（系统判分）'}}</text>
          <input wx:if="{{item.gradable}}" class="scoreInput" type="digit" value="{{item.scoreInput}}" data-idx="{{index}}" bindinput="onScoreInput" />
          <view wx:else class="scoreReadonly">{{item.earnedScore != null ? item.earnedScore : '—'}}</view>
        </view>
      </view>
    </block>
    <button wx:if="{{!gradingDone}}" class="btnPrimary" loading="{{saving}}" disabled="{{saving}}" bindtap="saveGrades">保存得分</button>
  </view>
</view>

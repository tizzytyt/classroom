<view class="page">
  <view class="card">
    <view class="sectionTitle">学生列表</view>
    <view class="sectionSub">教师可移除课程学生</view>

    <view wx:if="{{loading}}" class="tip">加载中...</view>
    <view wx:elif="{{students.length === 0}}" class="tip">暂无学生</view>

    <block wx:else>
      <view wx:for="{{students}}" wx:key="id" class="studentRow">
        <view class="studentMain">
          <view class="studentName">{{item.realName || item.username}}</view>
          <view class="studentSub">学号/账号：{{item.username}}</view>
        </view>
        <button class="btnDanger" size="mini" data-student-id="{{item.id}}" bindtap="removeStudent">移除</button>
      </view>
    </block>
  </view>
</view>


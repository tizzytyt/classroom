.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.sectionSub {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.tip {
  font-size: 26rpx;
  color: #888888;
  margin-top: 16rpx;
}

.studentRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1px solid #f5f5f5;
}

.studentMain {
  flex: 1;
}

.studentName {
  font-size: 28rpx;
  font-weight: 500;
}

.studentSub {
  font-size: 24rpx;
  color: #666666;
  margin-top: 6rpx;
}

.btnDanger {
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #ffffff;
  border: none;
  width: 160rpx;
  margin-left: 16rpx;
}


.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tip {
  font-size: 26rpx;
  color: #888888;
}

.meta {
  font-size: 26rpx;
  color: #666666;
  margin-top: 8rpx;
}

.meta.strong {
  color: #333333;
  font-weight: 600;
}

.progressTrack {
  height: 14rpx;
  border-radius: 999rpx;
  background: #f0f0f0;
  overflow: hidden;
  margin-top: 14rpx;
}

.progressFill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4b7cff 0%, #6fa4ff 100%);
  max-width: 100%;
}

.divider {
  height: 1px;
  background: #f0f0f0;
  margin-top: 18rpx;
  margin-bottom: 8rpx;
}

.distRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
}

.distLeft {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.distRight {
  font-size: 24rpx;
  color: #666666;
}

.barTrack {
  height: 14rpx;
  border-radius: 999rpx;
  background: #f0f0f0;
  overflow: hidden;
  margin-top: 10rpx;
}

.barFill {
  height: 100%;
  border-radius: 999rpx;
  max-width: 100%;
}

.barEx {
  background: linear-gradient(90deg, #52c41a 0%, #73d13d 100%);
}

.barGood {
  background: linear-gradient(90deg, #1677ff 0%, #69b1ff 100%);
}

.barPass {
  background: linear-gradient(90deg, #faad14 0%, #ffd666 100%);
}

.barFail {
  background: linear-gradient(90deg, #ff4d4f 0%, #ff7875 100%);
}

.item {
  padding: 16rpx 0;
  border-top: 1px solid #f5f5f5;
}

.name {
  font-size: 28rpx;
  color: #333333;
}


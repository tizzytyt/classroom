<view class="page">
  <view class="card" wx:if="{{isTeacher}}">
    <view class="sectionTitle">发布学习资源</view>
    <view class="sectionSub">选择文件后将自动填充标题和分类，并上传发布到课程</view>

    <input class="input" placeholder="资源标题" value="{{publishForm.title}}" bindinput="onPublishTitleInput" />
    <input class="input inputTop" placeholder="资源简介（选填）" value="{{publishForm.description}}" bindinput="onPublishDescInput" />
    <input class="input inputTop" placeholder="资源分类（必填，如 文档/课件）" value="{{publishForm.category}}" bindinput="onPublishCategoryInput" />

    <button class="btnPrimary btnUpload" loading="{{uploading}}" disabled="{{uploading}}" bindtap="chooseAndUploadFile">选择文件并上传</button>
  </view>

  <view class="card">
    <view class="title">课程资源</view>
    <view wx:if="{{loading}}" class="tip">加载中...</view>
    <view wx:elif="{{!list.length}}" class="tip">暂无资源</view>
    <block wx:else>
      <view wx:for="{{list}}" wx:key="id" class="item">
        <view class="name">
          {{item.title}}
          <text wx:if="{{item.learned || learnedMap[item.id]}}" class="learnedCheck">✅</text>
        </view>
        <view class="meta">{{item.category}} · {{item.fileName}}</view>
        <view class="meta">大小：{{item.fileSize}} 字节</view>
        <view wx:if="{{isTeacher}}" class="teacherOpsRow">
          <button size="mini" class="miniBtn" data-id="{{item.id}}" bindtap="startEdit">编辑</button>
          <button size="mini" class="miniDangerBtn" data-id="{{item.id}}" bindtap="deleteResource">删除</button>
        </view>
        <view wx:if="{{!isTeacher}}" class="studentOpsRow">
          <button size="mini" class="miniBtn" data-id="{{item.id}}" bindtap="openResource">
            {{ isVideo(item.fileType, item.fileName) ? '观看视频' : '打开文件' }}
          </button>
        </view>
      </view>
    </block>
  </view>

  <view class="card" wx:if="{{isTeacher && editingResourceId}}">
    <view class="sectionTitle">编辑资源信息</view>
    <input class="input" placeholder="资源标题" value="{{editForm.title}}" bindinput="onEditTitleInput" />
    <input class="input inputTop" placeholder="资源简介（选填）" value="{{editForm.description}}" bindinput="onEditDescInput" />
    <input class="input inputTop" placeholder="资源分类（必填）" value="{{editForm.category}}" bindinput="onEditCategoryInput" />
    <button class="btnPrimary" loading="{{savingEdit}}" bindtap="saveEdit">保存</button>
    <button class="btnGhost" bindtap="cancelEdit">取消</button>
  </view>
</view>


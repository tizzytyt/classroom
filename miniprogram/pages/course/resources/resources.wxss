.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.tip {
  font-size: 26rpx;
  color: #888888;
}

.item {
  padding: 16rpx 0;
  border-top: 1px solid #f5f5f5;
}

.name {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.learnedCheck {
  margin-left: 12rpx;
  font-size: 28rpx;
}

.meta {
  font-size: 24rpx;
  color: #666666;
}

.miniBtn {
  margin-top: 10rpx;
}

.sectionTitle {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.sectionSub {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.inputTop {
  margin-top: 12rpx;
}

.btnPrimary {
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4b7cff 0%, #6fa4ff 100%);
  color: #ffffff;
  border: none;
}

.btnUpload {
  margin-top: 12rpx;
}

.teacherOpsRow {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 10rpx;
}

.studentOpsRow {
  display: flex;
  justify-content: flex-start;
  gap: 16rpx;
  margin-top: 10rpx;
  flex-wrap: wrap;
}

.miniDangerBtn {
  margin: 0;
  font-size: 24rpx;
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #ffffff;
  border: none;
}

.btnGhost {
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #f5f6fb;
  color: #333333;
  border: none;
}


.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sectionSub {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.switchRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 4rpx 20rpx;
}

.switchLabel {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.draftSectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  margin: 24rpx 0 12rpx;
}

.typeRow {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.typeBtn {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  background: #fafafa;
  text-align: center;
}

.typeBtnOn {
  border-color: #4b7cff;
  background: #e8f0ff;
  color: #4b7cff;
  font-weight: 500;
}

.row2 {
  display: flex;
  gap: 16rpx;
}

.inputLabel {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  color: #666666;
  padding: 0 8rpx;
  white-space: nowrap;
}

.row2 .input {
  flex: 1;
}

.timeBlock {
  margin-bottom: 20rpx;
}

.timeLabel {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.timeRow {
  display: flex;
  gap: 16rpx;
}

.pickerCell {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  font-size: 26rpx;
  color: #333333;
  background: #fafafa;
  box-sizing: border-box;
}

.pickerCellFull {
  flex: none;
  width: 100%;
  margin-bottom: 16rpx;
}

.draftItem {
  padding: 16rpx 0;
  border-top: 1px solid #f0f0f0;
}

.draftItemTop {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.draftOps {
  display: flex;
  gap: 12rpx;
}

.draftMini {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.editHint {
  font-size: 24rpx;
  color: #4b7cff;
  margin-bottom: 12rpx;
}

.btnPrimary {
  margin-top: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4b7cff 0%, #6fa4ff 100%);
  color: #ffffff;
  border: none;
}

.btnGhost {
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  color: #666666;
  border: none;
}


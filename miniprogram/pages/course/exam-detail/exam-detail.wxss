.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.meta {
  font-size: 26rpx;
  color: #666666;
  margin-top: 6rpx;
}

.badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.badge-draft {
  background: #fff7e6;
  color: #d48806;
}

.badge-live {
  background: #f6ffed;
  color: #389e0d;
}

.badge-off {
  background: #f5f5f5;
  color: #888888;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.typeRow {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.typeBtn {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  background: #fafafa;
  text-align: center;
}

.typeBtnOn {
  border-color: #4b7cff;
  background: #e8f0ff;
  color: #4b7cff;
  font-weight: 500;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.row2 {
  display: flex;
  gap: 16rpx;
}

.inputLabel {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  color: #666666;
  padding: 0 8rpx;
  white-space: nowrap;
}

.row2 .input {
  flex: 1;
}

.btnPrimary {
  margin-top: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4b7cff 0%, #6fa4ff 100%);
  color: #ffffff;
  border: none;
}

.btnGhost {
  margin-top: 12rpx;
  border-radius: 999rpx;
}

.btnRow {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.btnRow .btnPrimary,
.btnRow .btnGhost {
  flex: 1;
  margin-top: 0;
}

.btnRow {
  flex-wrap: wrap;
}

.btnRow .btnPrimary,
.btnRow .btnGhost {
  min-width: 200rpx;
}

.qItem {
  padding: 20rpx 0;
  border-top: 1px solid #f0f0f0;
}

.qStem {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.qMeta {
  font-size: 24rpx;
  color: #666666;
}

.optLine {
  font-size: 24rpx;
  color: #444444;
  margin-top: 4rpx;
  padding-left: 8rpx;
}

.tip {
  font-size: 24rpx;
  color: #888888;
}

.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tip {
  font-size: 26rpx;
  color: #666666;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-top: 12rpx;
}

.stat {
  background: #fafafa;
  border: 1px solid #f0f0f0;
  border-radius: 16rpx;
  padding: 18rpx;
}

.statLabel {
  font-size: 24rpx;
  color: #888888;
}

.statValue {
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
}

.row {
  padding: 14rpx 0;
  border-top: 1px solid #f5f5f5;
}

.name {
  font-size: 28rpx;
  color: #333333;
}

.sub {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #888888;
}


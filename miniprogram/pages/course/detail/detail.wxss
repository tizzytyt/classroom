.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.sub {
  font-size: 26rpx;
  color: #666666;
  margin-top: 8rpx;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.sectionSub {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.weightRow {
  display: flex;
  gap: 12rpx;
}

.weightLabelRow {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.weightLabel {
  flex: 1;
  min-width: 0;
  text-align: center;
  font-size: 24rpx;
  color: #666666;
}

.weightInput {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 0 8rpx;
}

.btn {
  margin-top: 16rpx;
  border-radius: 999rpx;
}

.teacherOps {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
}

.btnSmall {
  margin: 0;
  font-size: 24rpx;
  border-radius: 999rpx;
}

.btnDangerSmall {
  margin: 0;
  font-size: 24rpx;
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #ffffff;
  border: none;
}

.input {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.inputTop {
  margin-top: 12rpx;
}

.finalScoreRow {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: #f7f8fc;
}

.finalScoreLabel {
  font-size: 26rpx;
  color: #666666;
}

.finalScoreValue {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}


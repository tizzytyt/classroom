.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tip {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.sectionSub {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 16rpx;
  line-height: 1.45;
}

.deadlineSwitchRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 8rpx 0;
}

.deadlineSwitchLabel {
  font-size: 28rpx;
  color: #333333;
}

.timeBlock {
  margin-bottom: 20rpx;
}

.timeLabel {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.timeRow {
  display: flex;
  gap: 16rpx;
}

.pickerCell {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  font-size: 26rpx;
  color: #333333;
  background: #fafafa;
  box-sizing: border-box;
}

/* 固定高度 + 行高与纵向居中，避免 input/placeholder 上下被裁切（与课程资源页一致） */
.input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.btn {
  border-radius: 999rpx;
}

.item {
  padding: 16rpx 0;
  border-top: 1px solid #f5f5f5;
}

.rowTop {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.rowTitle {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  border: 1px solid transparent;
  flex-shrink: 0;
}

.badgeOk {
  background: rgba(82, 196, 26, 0.12);
  color: #237804;
  border-color: rgba(82, 196, 26, 0.35);
}

.badgeNo {
  background: rgba(255, 77, 79, 0.10);
  color: #a8071a;
  border-color: rgba(255, 77, 79, 0.30);
}

.btnRow {
  margin-top: 12rpx;
  display: flex;
  gap: 16rpx;
}

.btnMini {
  border-radius: 999rpx;
}

.btnMiniDanger {
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #ffffff;
  border: none;
}


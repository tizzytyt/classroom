.page {
  min-height: 100vh;
  background-color: #ffffff;
}

.header {
  padding: 80rpx 40rpx 40rpx;
  color: #333333;
}

.hello {
  font-size: 28rpx;
  opacity: 0.9;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.roleTag {
  display: inline-block;
  margin-top: 12rpx;
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
  background: #f5f6fb;
  border: 1px solid #e0e3f0;
}

.sub {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #666666;
}

.content {
  margin-top: 0;
  padding: 0 24rpx 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.label {
  color: #666666;
}

.btnDanger {
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #ffffff;
  border: none;
}

.btnPrimary {
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4b7cff 0%, #6fa4ff 100%);
  color: #ffffff;
  border: none;
}

.sectionTitle {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sectionSub {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.weightHint {
  color: #888888;
  line-height: 1.45;
}

.weightRow {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.weightLabelRow {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.weightLabel {
  flex: 1;
  min-width: 0;
  text-align: center;
  font-size: 24rpx;
  color: #666666;
}

.weightInput {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 0 8rpx;
}

.joinRow {
  display: block;
}

.input {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  border: 1px solid #e5e5e5;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.joinRow .btnPrimary {
  display: block;
  width: 200rpx;
  margin: 16rpx auto 0;
}

.inputTop {
  margin-top: 12rpx;
}

.tip {
  font-size: 26rpx;
  color: #888888;
  margin-top: 8rpx;
}

.courseItem {
  padding: 16rpx 0;
  border-top: 1px solid #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.courseName {
  font-size: 28rpx;
  font-weight: 500;
}

.courseIntro {
  font-size: 24rpx;
  color: #666666;
  margin-top: 6rpx;
}

.courseArrow {
  font-size: 36rpx;
  color: #cccccc;
  padding-left: 16rpx;
}

.logoutCard {
  text-align: center;
}

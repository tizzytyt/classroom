.page {
  padding: 24rpx 0 24rpx;
}

.headerCard {
  margin: 24rpx;
  padding: 28rpx;
}

.headerTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
}

.headerSub {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(17, 17, 17, 0.55);
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx 18rpx;
}

.gridItem {
  width: 33.3333%;
  padding: 10rpx;
  box-sizing: border-box;
}

.gridItem > .num {
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
}

.gridItem > .lbl {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(17, 17, 17, 0.55);
}

.actionBtn {
  width: 100%;
  height: 88rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}
